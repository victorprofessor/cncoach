{
  "name": "cncoach",
  "version": "1.0.0",
  "description": "CnCoach - treinador de corrida por zonas de FC",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "copy:capacitor": "node -e \"const fs=require('fs');fs.mkdirSync('www/vendor/capacitor',{recursive:true});fs.copyFileSync('node_modules/@capacitor/core/dist/capacitor.js','www/vendor/capacitor/capacitor.js');fs.copyFileSync('node_modules/@capacitor-community/bluetooth-le/dist/plugin.js','www/vendor/capacitor/bluetooth-le.js');\"",
    "build:android": "npm run copy:capacitor && npx cap sync android",
    "build:ios": "npm run copy:capacitor && npx cap sync ios"
  },
  "repository": {
    "type": "git",
    "url": "http://local_proxy@127.0.0.1:41729/git/victorprofessor/cncoach"
  },
  "keywords": [],
